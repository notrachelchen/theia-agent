{
    "manifest_version": 3,
    "name": "Blind Browser Assistant",
    "version": "1.0.0",
    "description": "AI-powered browser assistant for blind users",
  
    "permissions": [
      "tabs",
      "activeTab",
      "scripting",
      "storage",
      "offscreen",
      "sidePanel",
      "microphone",
      "audioCapture",
      "tts"
    ],
  
    "host_permissions": [
      "<all_urls>"
    ],
  
    "background": {
      "service_worker": "background.js"
    },
  
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
  
    "side_panel": {
      "default_path": "sidebar.html"
    },
  
    "action": {
      "default_title": "Blind Browser Assistant",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    }
  }